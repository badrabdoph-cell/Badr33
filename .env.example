# Server
ADMIN_ALLOW_DEFAULTS="false"
ADMIN_FORCE_FILE_STORE="true"
ADMIN_GITHUB_BRANCH="main"
ADMIN_GITHUB_REPO="owner/repo"
ADMIN_GITHUB_SYNC="true"
ADMIN_GITHUB_TOKEN="change-me"
ADMIN_LOGIN_FORCE_ENABLE="false"
ADMIN_PASS="change-me"
ADMIN_STORE_MODE="file"
ADMIN_USER="change-me"
JWT_SECRET="change-me"

# MySQL
# Set a full database URL for this app when using the DB-backed store.
DATABASE_URL="mysql://USER:PASS@HOST:3306/DB_NAME"

# Railway-style MySQL variables (optional)
MYSQL_DATABASE="railway"
MYSQL_PUBLIC_URL="mysql://${MYSQLUSER}:${MYSQL_ROOT_PASSWORD}@${RAILWAY_TCP_PROXY_DOMAIN}:${RAILWAY_TCP_PROXY_PORT}/${MYSQL_DATABASE}"
MYSQL_ROOT_PASSWORD="change-me"
MYSQL_URL="mysql://${MYSQLUSER}:${MYSQL_ROOT_PASSWORD}@${RAILWAY_PRIVATE_DOMAIN}:3306/${MYSQL_DATABASE}"
MYSQLDATABASE="${MYSQL_DATABASE}"
MYSQLHOST="${RAILWAY_PRIVATE_DOMAIN}"
MYSQLPASSWORD="${MYSQL_ROOT_PASSWORD}"
MYSQLPORT="3306"
MYSQLUSER="root"
